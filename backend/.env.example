# WhoIsThat Backend Configuration (Multi-Site)
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Telegram Bot - Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# CORS - Fallback allowed origin when not using allowedSites (e.g. *)
CORS_ORIGIN=*

# Rate limiting - max requests per IP per minute
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Allowed sites are defined in backend/config/allowedSites.js (siteId + domains).
# Add new websites there, then redeploy.
